{
  "name": "propshare-backend",
  "version": "1.0.0",
  "description": "PropShare – Fractional Real Estate Investment Platform Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build": "prisma generate --schema=prisma/schema/schema.prisma && tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate --schema=prisma/schema/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=prisma/schema/schema.prisma",
    "db:studio": "prisma studio --schema=prisma/schema/schema.prisma",
    "db:push": "prisma db push --schema=prisma/schema/schema.prisma",
    "postinstall": "prisma generate --schema=prisma/schema/schema.prisma"
  },
  "keywords": [
    "real-estate",
    "investment",
    "fractional",
    "propshare"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^7.0.11",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "http-status": "^2.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "stripe": "^17.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.13.10",
    "@types/pg": "8.11.11",
    "prisma": "^7.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}