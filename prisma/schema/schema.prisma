// PropShare - Prisma Schema
// Learn more: https://pris.ly/d/prisma-schema

generator client {
    provider   = "prisma-client-js"
    engineType = "library"
}

datasource db {
    provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
    ADMIN
    USER
}

enum PropertyStatus {
    DRAFT
    PENDING
    UNDER_REVIEW
    APPROVED
    REJECTED
}

enum VoteType {
    UPVOTE
    DOWNVOTE
}

enum PaymentStatus {
    PENDING
    SUCCESS
    FAILED
}

// ─── USER ─────────────────────────────────────────────────────────────────────

model User {
    id        String   @id @default(cuid())
    name      String
    email     String   @unique
    password  String?
    role      Role     @default(USER)
    isActive  Boolean  @default(true)
    avatar    String?
    bio       String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    properties  Property[]
    votes       Vote[]
    comments    Comment[]
    investments Investment[]
    accounts    Account[]

    @@map("users")
}

// ─── ACCOUNT (OAuth) ─────────────────────────────────────────────────────────

model Account {
    id                String   @id @default(cuid())
    userId            String
    provider          String
    providerAccountId String
    accessToken       String?
    refreshToken      String?
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
    @@index([userId])
    @@map("accounts")
}

// ─── CATEGORY ─────────────────────────────────────────────────────────────────

model Category {
    id          String   @id @default(cuid())
    name        String   @unique
    description String?
    icon        String?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    properties Property[]

    @@map("categories")
}

// ─── PROPERTY ─────────────────────────────────────────────────────────────────

model Property {
    id               String         @id @default(cuid())
    title            String
    location         String
    description      String
    problemStatement String? // Context: Why this investment? (Mapped from EcoSpark Problem Statement)
    proposedSolution String? // Context: High potential (Mapped from EcoSpark Proposed Solution)
    images           String[]       @default([])
    pricePerShare    Float
    totalShares      Int
    availableShares  Int
    expectedReturn   Float? // ROI
    isPaid           Boolean        @default(false)
    status           PropertyStatus @default(DRAFT)
    feedbackNote     String?
    isFeatured       Boolean        @default(false)
    viewCount        Int            @default(0)
    categoryId       String
    authorId         String
    createdAt        DateTime       @default(now())
    updatedAt        DateTime       @updatedAt

    author      User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
    category    Category     @relation(fields: [categoryId], references: [id])
    votes       Vote[]
    comments    Comment[]
    investments Investment[]

    @@index([authorId])
    @@index([categoryId])
    @@index([status])
    @@map("properties")
}

// ─── VOTE (Interest/Upvote) ──────────────────────────────────────────────────

model Vote {
    id         String   @id @default(cuid())
    userId     String
    propertyId String
    voteType   VoteType
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

    @@unique([userId, propertyId])
    @@index([propertyId])
    @@map("votes")
}

// ─── COMMENT ──────────────────────────────────────────────────────────────────

model Comment {
    id         String   @id @default(cuid())
    content    String
    isDeleted  Boolean  @default(false)
    userId     String
    propertyId String
    parentId   String?
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    property Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
    parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
    replies  Comment[] @relation("CommentReplies")

    @@index([propertyId])
    @@index([parentId])
    @@map("comments")
}

// ─── INVESTMENT ────────────────────────────────────────────────────────────────

model Investment {
    id              String        @id @default(cuid())
    userId          String
    propertyId      String
    amount          Float
    shares          Int           @default(1)
    paymentProvider String        @default("stripe")
    stripeSessionId String?
    stripePaymentId String?
    status          PaymentStatus @default(PENDING)
    createdAt       DateTime      @default(now())
    updatedAt       DateTime      @updatedAt

    user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([propertyId])
    @@map("investments")
}
